# Restaurant App - Environment Configuration

# ======================
# SERVER CONFIGURATION
# ======================
PORT=5000
NODE_ENV=development

# Frontend URL für CORS & WebSocket
FRONTEND_URL=http://localhost:5173

# ======================
# DATABASE
# ======================
MONGO_URI=mongodb://mongo:27017/restaurant_db

# ======================
# AUTHENTICATION
# ======================
# WICHTIG: Für Production NEUE SECRET generieren!
# Generate: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Refresh Token (optional)
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRE=30d

# ======================
# LOGGING
# ======================
LOG_LEVEL=info

# ======================
# RATE LIMITING
# ======================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ======================
# BUSINESS LOGIC
# ======================
# Maximale Bestellen pro Zeitfenster
MAX_ORDERS_PER_HOUR=100

# Bestellprioritäten (in Minuten)
ORDER_WARNING_TIME_MINUTES=15
ORDER_CRITICAL_TIME_MINUTES=20
